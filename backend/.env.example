# OKX API Credentials (NEVER expose real keys)
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET_KEY=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here

# X Layer Mainnet Configuration
X_LAYER_RPC=https://rpc.xlayer.tech
CHAIN_ID=196

# Agent Wallet Address
AGENT_WALLET=0x0000000000000000000000000000000000000000

# Backend Server Configuration
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000

# Agent Loop Configuration
LOOP_INTERVAL_SECS=30
LIQUIDATION_THRESHOLD=1.2
MAX_BORROW_AMOUNT=10.0
MIN_BORROW_AMOUNT=0.1

# JWT Authentication Configuration
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-change-this-in-production
# Token expiry in seconds (default: 86400 = 24 hours)
JWT_TOKEN_EXPIRY_SECS=86400
# Enable authentication (true/false)
AUTH_ENABLED=false
